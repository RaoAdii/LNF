# Environment Variables Example

Copy this to a `.env` file in the backend directory and fill in your values.

PORT=5000

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas Dashboard
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/lost-found-hub?retryWrites=true&w=majority

# JWT Secret Key - Use a strong, random string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Token Expiration
JWT_EXPIRES_IN=7d

# Node Environment
NODE_ENV=development

# MongoDB connection retry controls
DB_MAX_ATTEMPTS=3
DB_RETRY_DELAY_MS=5000

# Frontend origin allowed by CORS (single origin)
# Example: https://app.example.com
FRONTEND_URL=http://localhost:5173

# Optional: comma-separated additional origins
# Example: https://admin.example.com,https://preview.example.com
CORS_ORIGINS=
